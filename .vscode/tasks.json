{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🔍 Lint (ruff)",
      "type": "shell",
      "command": "ruff check custom_components/",
      "group": "test",
      "presentation": { "reveal": "always" }
    },
    {
      "label": "🎨 Format (black)",
      "type": "shell",
      "command": "black custom_components/ tests/",
      "group": "build",
      "presentation": { "reveal": "always" }
    },
    {
      "label": "🔎 Type check (mypy)",
      "type": "shell",
      "command": "mypy custom_components/pool_filtration/",
      "group": "test",
      "presentation": { "reveal": "always" }
    },
    {
      "label": "🧪 Tous les tests",
      "type": "shell",
      "command": "pytest tests/ -v --cov=custom_components/pool_filtration --cov-report=term-missing",
      "group": { "kind": "test", "isDefault": true },
      "presentation": { "reveal": "always" }
    },
    {
      "label": "🏠 Démarrer Home Assistant",
      "type": "shell",
      "command": "hass --config config/ --debug",
      "group": "build",
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "✅ Vérification complète",
      "dependsOn": ["🔍 Lint (ruff)", "🔎 Type check (mypy)", "🧪 Tous les tests"],
      "dependsOrder": "sequence",
      "group": "test"
    }
  ]
}

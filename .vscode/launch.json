{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "🏠 Lancer Home Assistant",
      "type": "debugpy",
      "request": "launch",
      "module": "homeassistant",
      "justMyCode": false,
      "args": [
        "--config", "${workspaceFolder}/config",
        "--debug"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "🧪 Tests pytest",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "tests/",
        "-v",
        "--asyncio-mode=auto"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "🧪 Test fichier courant",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "${file}",
        "-v",
        "--asyncio-mode=auto"
      ]
    }
  ]
}
